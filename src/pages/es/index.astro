---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/ui';

const t = useTranslations('es');

const latestPosts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'es')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---

<Layout
  title="SEO local: guias y consejos para tu visibilidad local | visibilite-locale.online"
  description="Guias practicas, consejos y recursos sobre SEO local. Mejora tu visibilidad en Google Maps y la busqueda local."
  lang="es"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-700 via-blue-600 to-indigo-700 py-24 text-white">
    <!-- Circulos decorativos -->
    <div class="pointer-events-none absolute -top-24 -right-24 h-96 w-96 rounded-full bg-white/5"></div>
    <div class="pointer-events-none absolute -bottom-16 -left-16 h-64 w-64 rounded-full bg-white/5"></div>
    <div class="pointer-events-none absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/[0.03]"></div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <!-- Texto -->
        <div>
          <span class="mb-5 inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-sm font-semibold backdrop-blur-sm">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            La guia del SEO local
          </span>
          <h1 class="mb-5 text-4xl font-extrabold leading-tight sm:text-5xl">
            {t('hero.title')}
          </h1>
          <p class="mb-8 text-lg text-blue-100 leading-relaxed max-w-lg">
            {t('hero.subtitle')}
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/es/guide-seo-local" class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-blue-700 shadow-lg transition hover:bg-blue-50">
              {t('hero.cta')}
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/es/blog" class="inline-flex items-center gap-2 rounded-xl border border-white/30 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
              Leer el blog
            </a>
          </div>
        </div>

        <!-- Ilustracion -->
        <div class="hidden lg:flex justify-center">
          <div class="relative">
            <!-- Tarjeta Google Maps estilizada -->
            <div class="rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 p-6 shadow-2xl w-72">
              <div class="mb-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20">
                  <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                </div>
                <div>
                  <div class="h-2.5 w-28 rounded bg-white/40"></div>
                  <div class="mt-1.5 h-2 w-20 rounded bg-white/20"></div>
                </div>
              </div>
              <!-- Estrellas -->
              <div class="mb-3 flex gap-1">
                {[1,2,3,4,5].map(() => <svg class="h-4 w-4 text-yellow-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
              </div>
              <div class="space-y-2">
                <div class="h-2 w-full rounded bg-white/20"></div>
                <div class="h-2 w-5/6 rounded bg-white/20"></div>
                <div class="h-2 w-4/6 rounded bg-white/20"></div>
              </div>
              <!-- Badge "Pack local" -->
              <div class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-green-400/20 px-3 py-1 text-xs font-semibold text-green-200">
                <span class="h-1.5 w-1.5 rounded-full bg-green-300"></span>
                Pack local de Google
              </div>
            </div>
            <!-- Badge flotante -->
            <div class="absolute -top-4 -right-4 rounded-xl bg-yellow-400 px-3 py-1.5 text-xs font-bold text-yellow-900 shadow-lg">
              +46% de clics
            </div>
          </div>
        </div>
      </div>

      <!-- Estadisticas -->
      <div class="mt-16 grid grid-cols-3 gap-6 border-t border-white/20 pt-10">
        {[
          { val: '46%', label: 'de las busquedas tienen intencion local' },
          { val: '3x', label: 'mas visitas con una ficha GBP completa' },
          { val: '80%', label: 'de las busquedas locales desde movil' },
        ].map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-white">{s.val}</div>
            <div class="mt-1 text-sm text-blue-200">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ultimos articulos -->
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mb-10 flex items-end justify-between">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-blue-600">Blog</span>
          <h2 class="mt-1 text-3xl font-bold text-gray-900">{t('latest.title')}</h2>
        </div>
        <a href="/es/blog" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-blue-600 hover:underline">
          Todos los articulos
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post, i) => (
          <li class="group flex flex-col rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
            <!-- Header coloreado -->
            <div class={`h-2 w-full ${['bg-blue-500','bg-indigo-500','bg-violet-500','bg-emerald-500','bg-orange-500','bg-rose-500'][i % 6]}`}></div>
            <a href={`/es/blog/${post.slug}/`} class="flex flex-col flex-1 p-6">
              <p class="text-xs text-gray-400 mb-3">{post.data.date}</p>
              <h3 class="text-base font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug flex-1">{post.data.title}</h3>
              <p class="mt-3 text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-blue-600">
                Leer el articulo
                <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-8 text-center sm:hidden">
        <a href="/es/blog" class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 hover:underline">
          Todos los articulos →
        </a>
      </div>
    </div>
  </section>

  <!-- Tematicas -->
  <section class="bg-gray-50 py-20 border-t border-gray-200">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mb-10">
        <span class="text-xs font-bold uppercase tracking-widest text-blue-600">Recursos</span>
        <h2 class="mt-1 text-3xl font-bold text-gray-900">Tematicas</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { icon: '\u{1F4CD}', title: 'Google Business Profile', desc: 'Optimiza tu ficha de establecimiento para aparecer en el pack local.', href: '/es/guide-seo-local/google-business-profile', color: 'blue' },
          { icon: '\u{1F5C2}\uFE0F', title: 'Citas locales', desc: 'Directorios, NAP y coherencia de tu informacion online.', href: '/es/guide-seo-local/citas-locales', color: 'indigo' },
          { icon: '\u2B50', title: 'Resenas de clientes', desc: 'Como obtener y gestionar tus resenas de Google para el SEO.', href: '/es/guide-seo-local/resenas-clientes', color: 'yellow' },
          { icon: '\u270D\uFE0F', title: 'Contenido local', desc: 'Crea paginas y articulos dirigidos a tu zona geografica.', href: '/es/guide-seo-local/contenido-local', color: 'emerald' },
          { icon: '\u{1F517}', title: 'Backlinks locales', desc: 'Consigue enlaces desde sitios web de tu region.', href: '/es/guide-seo-local/backlinks-locales', color: 'violet' },
          { icon: '\u{1F3EA}', title: 'SEO local para comercios', desc: 'Estrategias adaptadas a tiendas, restaurantes y artesanos.', href: '/es/guide-seo-local/comercios', color: 'rose' },
        ].map(item => (
          <a href={item.href} class="group flex items-start gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-blue-200">
            <span class="text-2xl">{item.icon}</span>
            <div>
              <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{item.title}</h3>
              <p class="mt-1 text-sm text-gray-500 leading-relaxed">{item.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-3xl font-bold text-gray-900">Listo para dominar tu mercado local?</h2>
      <p class="mt-4 text-lg text-gray-500">Empieza con nuestra guia completa de SEO local — gratis y sin registro.</p>
      <a href="/es/guide-seo-local" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-blue-600 px-8 py-4 text-sm font-bold text-white shadow-lg transition hover:bg-blue-700">
        Acceder a la guia gratuita
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>
