---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(p => p.data.lang === 'es')
    .map(post => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const siteUrl = 'https://visibilite-locale.online';
const articleUrl = `${siteUrl}/es/blog/${post.slug}/`;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  url: articleUrl,
  inLanguage: 'es',
  image: post.data.image ? `${siteUrl}${post.data.image}` : undefined,
  publisher: {
    '@type': 'Organization',
    name: 'visibilite-locale.online',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
};

const faqJsonLd = post.data.faqs?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.data.faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
} : null;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  lang="es"
  article={{ date: post.data.date }}
  jsonLd={articleJsonLd}
  additionalJsonLds={faqJsonLd ? [faqJsonLd] : []}
  ogImage={post.data.image}
>
  <!-- Header article -->
  <div class="relative overflow-hidden bg-gradient-to-br from-blue-700 to-indigo-700 py-16 text-white">
    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.title}
        class="absolute inset-0 h-full w-full object-cover opacity-20 mix-blend-overlay"
        loading="eager"
        width="1200"
        height="630"
      />
    )}
    <div class="relative mx-auto max-w-3xl px-4">
      <a href="/es/blog" class="mb-6 inline-flex items-center gap-1.5 text-sm text-blue-200 hover:text-white transition-colors">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Volver al blog
      </a>
      <p class="text-sm text-blue-200 mb-3">{post.data.date}</p>
      <h1 class="text-3xl font-extrabold leading-tight sm:text-4xl">{post.data.title}</h1>
      <p class="mt-4 text-lg text-blue-100 leading-relaxed">{post.data.description}</p>
    </div>
  </div>

  <!-- Contenido -->
  <article class="mx-auto max-w-3xl px-4 py-14">
    <div class="prose">
      <Content />
    </div>

    <!-- FAQ -->
    {post.data.faqs?.length ? (
      <div class="mt-14">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Preguntas frecuentes</h2>
        <div class="space-y-3">
          {post.data.faqs.map(faq => (
            <details class="rounded-xl border border-gray-200 bg-white p-5 open:shadow-sm">
              <summary class="cursor-pointer font-semibold text-gray-900 list-none flex justify-between items-center gap-3">
                {faq.question}
                <svg class="h-5 w-5 flex-shrink-0 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <p class="mt-3 text-sm text-gray-600 leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    ) : null}

    <!-- CTA -->
    <div class="mt-16 rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-600 p-8 text-white text-center">
      <h2 class="text-xl font-bold">Mejora tu visibilidad local</h2>
      <p class="mt-2 text-blue-100 text-sm">Consulta nuestra guia completa para dominar los resultados locales en Google.</p>
      <a href="/es/guide-seo-local" class="mt-5 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-blue-700 transition hover:bg-blue-50">
        Acceder a la guia gratuita →
      </a>
    </div>
  </article>
</Layout>
