---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const colors = ['bg-blue-500','bg-indigo-500','bg-violet-500','bg-emerald-500','bg-orange-500','bg-rose-500'];
---

<Layout
  title="Local SEO Blog | visibilite-locale.online"
  description="Articles, tips and advice on local SEO."
  lang="en"
>
  <!-- Hero -->
  <section class="border-b border-gray-200 bg-gradient-to-br from-blue-50 to-indigo-50 py-16">
    <div class="mx-auto max-w-5xl px-4">
      <span class="text-xs font-bold uppercase tracking-widest text-blue-600">Blog</span>
      <h1 class="mt-2 text-4xl font-extrabold text-gray-900">Local SEO Articles</h1>
      <p class="mt-3 text-lg text-gray-600 max-w-xl">Practical guides, analyses and tips to improve your local search rankings.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-5xl px-4">
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => (
          <li class="group flex flex-col rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden">
            <div class={`h-2 w-full ${colors[i % colors.length]}`}></div>
            <a href={`/en/blog/${post.slug}/`} class="flex flex-col flex-1 p-6">
              <p class="text-xs text-gray-400 mb-3">{post.data.date}</p>
              <h2 class="text-base font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug flex-1">{post.data.title}</h2>
              <p class="mt-3 text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-blue-600">
                Read the article
                <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
