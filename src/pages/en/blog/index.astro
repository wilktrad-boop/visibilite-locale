---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout
  title="Local SEO Blog | visibilite-locale.online"
  description="Articles, tips and advice on local SEO."
  lang="en"
>
  <section class="border-b border-gray-200 bg-gray-50 py-14">
    <div class="mx-auto max-w-5xl px-4">
      <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
      <p class="mt-3 text-lg text-gray-600">Articles and advice on local search engine optimization.</p>
    </div>
  </section>

  <section class="py-14">
    <div class="mx-auto max-w-5xl px-4">
      <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <li class="rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <a href={`/en/blog/${post.slug}/`}>
              <p class="text-xs text-gray-400 mb-2">{post.data.date}</p>
              <h2 class="text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors">{post.data.title}</h2>
              <p class="mt-2 text-sm text-gray-600 line-clamp-3">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
